{
  "uid": "medibook-overview",
  "title": "MediBook Services Overview",
  "description": "Overview dashboard for MediBook microservices",
  "tags": ["medibook", "microservices", "healthcare"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate by Service",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum by (service) (rate(http_requests_total[1m]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "reqps"
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 2,
      "title": "Error Rate by Service",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum by (service) (rate(http_requests_total{status_code=~\"5..\"}[1m])) / sum by (service) (rate(http_requests_total[1m]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "percentunit",
          "max": 1,
          "min": 0
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 3,
      "title": "Response Time (p95) by Service",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (service, le) (rate(http_request_duration_seconds_bucket[1m])))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "s"
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 4,
      "title": "Request Duration Distribution",
      "type": "heatmap",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum by (le) (rate(http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "{{le}}",
          "refId": "A",
          "format": "heatmap"
        }
      ],
      "options": {
        "calculate": false,
        "color": {
          "scheme": "Spectral"
        }
      }
    },
    {
      "id": 5,
      "title": "Service Status",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "up{job=\"gateway\"}",
          "refId": "A"
        },
        {
          "expr": "up{job=\"auth-service\"}",
          "refId": "B"
        },
        {
          "expr": "up{job=\"appointment-service\"}",
          "refId": "C"
        },
        {
          "expr": "up{job=\"notification-service\"}",
          "refId": "D"
        }
      ],
      "options": {
        "displayMode": "list",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 6,
      "title": "Memory Usage by Service",
      "type": "gauge",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 16
      },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=~\".*-service\"} / 1024 / 1024",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "MiB"
        }
      }
    },
    {
      "id": 7,
      "title": "Active Connections",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "expr": "node_netstat_Tcp_CurrEstab",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "CPU Usage by Service",
      "type": "gauge",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 16
      },
      "targets": [
        {
          "expr": "process_cpu_seconds_total{job=~\".*-service\"}",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 100,
          "min": 0
        }
      }
    },
    {
      "id": 9,
      "title": "Total Requests",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "targets": [
        {
          "expr": "sum(http_requests_total)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "refresh": 2,
        "query": "label_values(http_requests_total, service)",
        "includeAll": true,
        "multi": true
      }
    ]
  }
}
